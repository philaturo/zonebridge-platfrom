# ============================================================================
# ZoneBridge Platform
# Editor Configuration
#
# This file defines consistent formatting rules across editors and IDEs.
# https://editorconfig.org/
# ============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.go]
indent_style = tab

[*.mod]
indent_style = tab

[*.sum]
indent_style = tab

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

[*.css]
indent_size = 2

[*.scss]
indent_size = 2

[*.html]
indent_size = 2

[Makefile]
indent_style = tab